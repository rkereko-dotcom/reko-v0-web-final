# REKO Poster Generator - Environment Variables
# Copy this file to .env.local and fill in your API keys

# Required: Google AI API Key (for Gemini analysis + image generation)
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Gemini text model for analysis (default: gemini-1.5-pro-latest)
GEMINI_TEXT_MODEL=gemini-1.5-pro-latest

# Optional: HuggingFace Token (for Flux models)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Replicate API Token (for alternative models)
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Save generated images to disk (default: false)
SAVE_GENERATED_IMAGES=false

# Optional: Telemetry (global learning)
TELEMETRY_ENABLED=false
TELEMETRY_SUPABASE=false
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TELEMETRY_DIR=telemetry

# Optional: Prompt A/B policy file
# (default: prompts/prompt-policy.json)
PROMPT_POLICY_FILE=prompts/prompt-policy.json

# Optional: Reference gallery file
# (default: prompts/reference-gallery.json)
REFERENCE_GALLERY_FILE=prompts/reference-gallery.json
