# REKO Poster Generator - Environment Variables
# Copy this file to .env.local and fill in your keys.

# Required: Google AI API key (Gemini text + image endpoints)
GOOGLE_AI_API_KEY=AIzaSy_your_google_ai_key

# Optional: analyze model
GEMINI_TEXT_MODEL=gemini-1.5-pro-latest

# Optional: generate model (default in code: gemini-3-pro-image-preview)
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Optional: comma-separated fallback models
# Example: gemini-2.5-flash-image-preview,gemini-1.5-flash-latest
GEMINI_IMAGE_FALLBACK_MODELS=

# Optional: generation timeouts in milliseconds
GEMINI_REQUEST_TIMEOUT_MS=45000
GEMINI_VERIFY_TIMEOUT_MS=12000
GENERATE_SINGLE_IMAGE_TIMEOUT_MS=45000
GENERATE_TOTAL_TIMEOUT_MS=90000

# Optional: HuggingFace token (used for Flux provider)
HF_TOKEN=hf_your_hf_token

# Optional: Replicate token (used by background-removal path if enabled in code)
REPLICATE_API_TOKEN=r8_your_replicate_token

# Optional: save generated images to /generated-images
SAVE_GENERATED_IMAGES=false

# Optional: telemetry + required for api-register (user creation via admin API)
TELEMETRY_ENABLED=false
TELEMETRY_SUPABASE=false
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TELEMETRY_DIR=telemetry

# Optional: prompt/reference config files
PROMPT_POLICY_FILE=prompts/prompt-policy.json
REFERENCE_GALLERY_FILE=prompts/reference-gallery.json

# Optional: API Generate (external endpoint)
API_GENERATE_KEY=rekoswebtexttoimageapikey
API_GENERATE_ALLOWED_ORIGIN=https://your-external-site.com