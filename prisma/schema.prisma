generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  client
}

enum UserTier {
  free
  premium
}

model Profile {
  id        String   @id @db.Uuid
  email     String?
  role      UserRole @default(client)
  tier      UserTier @default(free)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  quotaResetAt     DateTime  @default(now()) @map("quota_reset_at")
  tokenBalance     Int       @default(0) @map("token_balance")
  premiumExpiresAt DateTime? @map("premium_expires_at")

  generationLogs  GenerationLog[]
  paymentLogs     PaymentLog[]
  tokenLogs       TokenLog[]

  @@map("profiles")
}

model GenerationLog {
  id         String   @id @default(cuid())
  userId     String   @db.Uuid @map("user_id")
  requestId  String   @map("request_id")
  source     String   // "studio" | "api"
  imageCount Int      @default(1) @map("image_count")
  createdAt  DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generation_logs")
}

model PaymentLog {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid @map("user_id")
  action    String   // "upgrade" | "renew" | "token_grant" | "qpay_token" | "qpay_premium"
  prevTier  String   @map("prev_tier")
  newTier   String   @map("new_tier")
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_logs")
}

model TokenLog {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid @map("user_id")
  amount    Int      // +N = нэмэгдсэн, -1 = зарцуулсан
  reason    String   // "admin_grant" | "qpay_purchase" | "generation_use"
  balance   Int      // гүйлгээний дараах үлдэгдэл
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("token_logs")
}

model SiteSettings {
  id                  String   @id @default("default")
  siteName            String   @default("Reko") @map("site_name")
  tabTitle            String   @default("Reko - AI Poster Generator") @map("tab_title")
  freeGenerationLimit Int      @default(5) @map("free_generation_limit")
  paidGenerationLimit Int      @default(50) @map("paid_generation_limit")
  premiumMonthlyPrice Int      @default(29900) @map("premium_monthly_price")
  tokenPrice          Int      @default(1000) @map("token_price")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
