generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  client
}

enum UserTier {
  free
  premium
}

model Profile {
  id        String   @id @db.Uuid
  email     String?
  role      UserRole @default(client)
  tier      UserTier @default(free)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  quotaResetAt DateTime @default(now()) @map("quota_reset_at")

  generatedImages GeneratedImage[]
  paymentLogs     PaymentLog[]

  @@map("profiles")
}

model GeneratedImage {
  id            String   @id @default(cuid())
  userId        String   @db.Uuid @map("user_id")
  filePath      String   @map("file_path")
  variationName String   @map("variation_name")
  requestId     String   @map("request_id")
  aspectRatio   String   @map("aspect_ratio")
  source        String   // "studio" | "api"
  createdAt     DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generated_images")
}

model PaymentLog {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid @map("user_id")
  action    String   // "upgrade" | "renew"
  prevTier  String   @map("prev_tier")
  newTier   String   @map("new_tier")
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_logs")
}

model SiteSettings {
  id                  String   @id @default("default")
  siteName            String   @default("Reko") @map("site_name")
  tabTitle            String   @default("Reko - AI Poster Generator") @map("tab_title")
  freeGenerationLimit Int      @default(5) @map("free_generation_limit")
  paidGenerationLimit Int      @default(50) @map("paid_generation_limit")
  premiumMonthlyPrice Int      @default(29900) @map("premium_monthly_price")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
